        "operation": "executeQuery",
        "query": "UPDATE actions\nSET status = 'cancelled',\n    rejection_reason = NULLIF('{{ $json.query.reason }}', ''),\n    rejection_routed_to = CASE\n      WHEN '{{ $json.query.reason }}' = 'stale_fact' THEN 'tabita'\n      WHEN '{{ $json.query.reason }}' = '' THEN NULL\n      ELSE 'engine' END,\n    decided_at = now()\nWHERE id = {{ $json.query.id }}\nRETURNING id, account, rejection_reason, rejection_routed_to, (select raw_payload from pipeline_runs where id = actions.run_id) as raw_payload, (select value from app_config where key='when_engine_url') as when_engine_url;",
