{
  "name": "Action Outcome Measurement Workflow",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 6
            }
          ]
        }
      },
      "id": "49c18e4a-d1ce-43d3-9dbb-97f4741a39c4",
      "name": "Schedule (daily)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -272,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, account, utm_campaign, predicted_metric, predicted_direction, threshold, executed_at, window_days\nFROM actions\nWHERE status = 'executed'\n  AND executed_at + (window_days || ' days')::interval <= now();",
        "options": {}
      },
      "id": "20d86c08-28ef-467d-955d-d788b31ffb78",
      "name": "Get Due Actions",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        64,
        0
      ],
      "credentials": {
        "postgres": {
          "id": "eR1uo2QGR2ZzwysA",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://analyticsdata.googleapis.com/v1beta/properties/{{ $('Get Config').first().json.ga4_property_id || '542471069' }}:runReport",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"dateRanges\": [{ \"startDate\": \"{{ $json.executed_at.toString().slice(0,10) }}\", \"endDate\": \"today\" }],\n  \"dimensions\": [{ \"name\": \"sessionManualCampaignName\" }],\n  \"metrics\": [{ \"name\": \"sessions\" }],\n  \"dimensionFilter\": { \"filter\": {\n    \"fieldName\": \"sessionManualCampaignName\",\n    \"stringFilter\": { \"value\": \"{{ $json.utm_campaign }}\" }\n  }}\n}",
        "options": {}
      },
      "id": "c7a64193-9b6f-4460-bb82-534216635b2e",
      "name": "Query GA4 (HTTP)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        448,
        0
      ],
      "credentials": {
        "googleApi": {
          "id": "y2gRhCm6qQpZSW4d",
          "name": "Google Service Account account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const a    = $('Get Due Actions').item.json;\nconst resp = $json;\nconst rows = resp.rows || [];\nconst measured = rows.reduce((s, r) => s + Number(r.metricValues?.[0]?.value || 0), 0);\nconst met = a.predicted_direction === 'increase'\n  ? measured >= Number(a.threshold)\n  : measured <= Number(a.threshold);\nreturn [{ json: {\n  action_id:       a.id,\n  measured_metric: a.predicted_metric,\n  measured_value:  measured,\n  result:          met ? 'met' : 'not_met',\n  source:          'ga4',\n  window_start:    a.executed_at,\n  window_end:      new Date().toISOString()\n}}];"
      },
      "id": "b17e86e7-f0d2-4e00-8554-5cd7fc699389",
      "name": "Evaluate vs Hypothesis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ]
    },
