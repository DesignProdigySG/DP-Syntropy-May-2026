    {
      "parameters": {
        "jsCode": "// Count reply emails attributed to this action's utm_campaign token.\n// Works for the 'email' channel when the outbound message carries the tracked link\n// (which embeds utm_campaign). LinkedIn DMs are NOT visible to Gmail.\nconst a = $('Loop Replies').first().json;          // the action row\nconst emails = $input.all();                       // matching messages (alwaysOutputData -> may be 1 empty item)\nconst replies = emails.filter(e => e.json && (e.json.id || e.json.threadId || e.json.snippet)).length;\nconst met = a.predicted_direction === 'increase'\n  ? replies >= Number(a.threshold)\n  : replies <= Number(a.threshold);\nreturn [{ json: {\n  action_id:       a.id,\n  measured_metric: a.predicted_metric,\n  measured_value:  replies,\n  result:          met ? 'met' : 'not_met',\n  source:          'gmail',\n  window_start:    a.executed_at,\n  window_end:      new Date().toISOString()\n}}];"
      },
