    {
      "parameters": {
        "jsCode": "// Recommend an action. Channel from coverage/engagement/trigger; tracking domain from app_config.\n// Also carries the WHEN engine's drafted outreach copy (outreach.action) through to the rep.\nconst cfg = $('Get Config').first().json || {};\nlet ENV_BASE_URL; try { ENV_BASE_URL = $env.TRACKING_BASE_URL; } catch (e) { ENV_BASE_URL = undefined; }\nconst baseUrl = (cfg.tracking_base_url && String(cfg.tracking_base_url).trim())\n  || ENV_BASE_URL\n  || 'https://example.com';\n\nconst item = $('Mark Brief Approved').first().json;   // pipeline_runs row\nconst account = item.company || 'unknown-account';\nconst runId   = item.id;\nconst trigger = item.trigger_type || '';\nconst cov     = (item.coverage_label || '').toUpperCase();\nconst engaged = Number(item.engaged_count || 0);\n\n// pull the WHEN engine's ready-made outreach message from the stored raw brief\nlet outreach_draft = '';\ntry {\n  const rp = typeof item.raw_payload === 'string' ? JSON.parse(item.raw_payload) : item.raw_payload;\n  outreach_draft = (rp && rp.outreach && rp.outreach.action) || (rp && rp.element_4 && rp.element_4.first_step) || '';\n} catch (e) { outreach_draft = ''; }\n\nconst CH = {\n  linkedin_post:    { metric:'page_visits',      channel:'linkedin',     medium:'social' },\n  linkedin_message: { metric:'reply_or_meeting', channel:'linkedin',     medium:'dm' },\n  email:            { metric:'reply_or_meeting', channel:'email',        medium:'outbound' },\n  content_send:     { metric:'page_visits',      channel:'email',        medium:'content' },\n  ad_retarget:      { metric:'page_visits',      channel:'linkedin_ads', medium:'paid_social' }\n};\n\nlet action_type;\nif (cov === 'BROAD') {\n  action_type = engaged >= 2 ? 'linkedin_message' : 'email';\n} else if (cov === 'PARTIAL') {\n  action_type = trigger ? 'linkedin_post' : 'content_send';\n} else if (cov === 'NARROW') {\n  action_type = trigger ? 'content_send' : 'ad_retarget';\n} else {\n  action_type = 'content_send';\n}\nconst c = CH[action_type];\n\nconst threshold = 1, window_days = 14;\nconst rand = Math.random().toString(36).slice(2,6);\nconst utm_campaign = `act-${runId}-${rand}`;\nconst sep = baseUrl.includes('?') ? '&' : '?';\nconst tracked_url = `${baseUrl}${sep}utm_source=${c.channel}&utm_medium=${c.medium}&utm_campaign=${utm_campaign}`;\nconst hypothesis = `If we run a ${action_type.replace(/_/g,' ')} for ${account}, then `\n  + `${c.metric.replace(/_/g,' ')} will increase by at least ${threshold} within ${window_days} days.`;\n\nreturn [{ json: {\n  run_id: runId, account, action_type, hypothesis, predicted_metric: c.metric,\n  predicted_direction: 'increase', threshold, window_days, utm_campaign, tracked_url,\n  status: 'recommended', outreach_draft\n}}];"
      },
