        "googleApi": {
          "id": "y2gRhCm6qQpZSW4d",
          "name": "Google Service Account account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// GA4 runReport rows -> one item per campaign\nconst rows = ($json.rows) || [];\nreturn rows.map(r => ({ json: {\n  campaign: r.dimensionValues?.[0]?.value || '(not set)',\n  sessions: Number(r.metricValues?.[0]?.value || 0)\n}}));"
      },
      "id": "b990be6c-26fe-46be-ae7b-baf8dda5c74b",
      "name": "Parse GA4 rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        -144
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO engagement_events (account, source, event_type, campaign, value, occurred_at)\nVALUES (\n  (SELECT account FROM actions WHERE utm_campaign = '{{ $json.campaign }}' ORDER BY id DESC LIMIT 1),\n  'ga4', 'page_visit', '{{ $json.campaign }}', {{ $json.sessions }}, now()\n);",
        "options": {}
      },
