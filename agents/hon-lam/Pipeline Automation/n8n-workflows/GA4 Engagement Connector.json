        "nodeCredentialType": "googleApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"dateRanges\": [{ \"startDate\": \"2daysAgo\", \"endDate\": \"today\" }],\n  \"dimensions\": [{ \"name\": \"sessionManualCampaignName\" }],\n  \"metrics\": [{ \"name\": \"sessions\" }]\n}",
        "options": {}
      },
