      "name": "When clicking ‘Execute workflow’"
    },
    {
      "parameters": {
        "jsCode": "const today = new Date();\n\nreturn $input.all().map(item => {\n  const buyingGroup = item.json.buyingGroup || [];\n\n  // Process each member in the buying group\n  const processedGroup = buyingGroup.map(member => {\n    const signals = member.signals || [];\n    const negativeSignals = member.negativeSignals || [];\n\n    // Weighted positive signals per member\n    const weighted = signals.map(s => {\n      const daysDiff = Math.floor((today - new Date(s.date)) / (1000*60*60*24));\n      let weight;\n      if (daysDiff <= 7) weight = \"HIGH\";\n      else if (daysDiff <= 30) weight = \"MEDIUM\";\n      else weight = \"LOW\";\n      return `${s.type} (${daysDiff} days ago, recency: ${weight})`;\n    });\n\n    // Parsed negative signals per member\n    const parsedNegative = negativeSignals.map(n => {\n      const daysDiff = Math.floor((today - new Date(n.date)) / (1000*60*60*24));\n      return `${n.type}: ${n.description} (${daysDiff} days ago)`;\n    });\n\n    return {\n      contactName: member.contactName,\n      jobTitle: member.jobTitle,\n      weightedSignals: weighted.join(', ') || 'No signals',\n      parsedNegativeSignals: parsedNegative.join(' | ') || 'None',\n      hasNegativeSignals: negativeSignals.length > 0,\n      engaged: signals.length > 0\n    };\n  });\n\n  // Buying group coverage calculation\n  const engagedCount = processedGroup.filter(m => m.engaged).length;\n  const totalCount = processedGroup.length;\n  const coveragePct = totalCount > 0 ? Math.round((engagedCount / totalCount) * 100) : 0;\n  const coverageLabel = coveragePct >= 66 ? \"BROAD\" : coveragePct >= 33 ? \"PARTIAL\" : \"NARROW\";\n  const engagedRoles = processedGroup.filter(m => m.engaged).map(m => `${m.contactName} (${m.jobTitle})`).join(', ');\n\n  // Aggregate all negative signals across buying group\n  const allNegativeSignals = processedGroup\n    .filter(m => m.hasNegativeSignals)\n    .map(m => `[${m.contactName}] ${m.parsedNegativeSignals}`)\n    .join(' | ');\n\n  const hasAnyNegativeSignals = processedGroup.some(m => m.hasNegativeSignals);\n\n  // Summary of all weighted signals across buying group\n  const allWeightedSignals = processedGroup\n    .filter(m => m.engaged)\n    .map(m => `[${m.contactName} - ${m.jobTitle}] ${m.weightedSignals}`)\n    .join(' | ');\n\n  return {\n    json: {\n      ...item.json,\n      buyingGroupProcessed: processedGroup,\n      allWeightedSignals,\n      allNegativeSignals: allNegativeSignals || 'None',\n      hasAnyNegativeSignals,\n      buyingGroupCoverage: coveragePct,\n      coverageLabel,\n      engagedRoles,\n      engagedCount,\n      totalCount\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3616,
        448
      ],
