    {
      "parameters": {
        "jsCode": "// Format Adapter\n// Handles three schemas:\n//   - Jocelyn (WHEN Layer): has meta.engine === \"WHEN Layer Intelligence Engine\"\n//   - Tabita (CaP context): has account_id + context_status\n//   - Pipeline native: has company + buyingGroup directly\n\nreturn $input.all().map(item => {\n  const data = item.json;\n\n  if (data.meta && data.meta.engine === \"WHEN Layer Intelligence Engine\") {\n    const accountSignals = data.signals || [];\n    const firstSignal = accountSignals[0] || {};\n\n    const buyingGroup = (data.buying_group || []).map(member => {\n      const status = (member.status || \"\").toString().toUpperCase();\n      const isConfirmed = status === \"COMPLETE\" || status === \"CONFIRMED\";\n      return {\n        contactName: member.name,\n        jobTitle: member.title,\n        signals: isConfirmed ? accountSignals.map(s => ({ type: s.type, date: s.date })) : [],\n        negativeSignals: []\n      };\n    });\n\n    const unenriched = (data.buying_group || []).filter(m => {\n      const s = (m.status || \"\").toString().toUpperCase();\n      return s !== \"COMPLETE\" && s !== \"CONFIRMED\";\n    });\n    const enrichmentNeeded = unenriched.length > 0;\n    const unenrichedRoles = unenriched.map(m => m.name + (m.focus_area ? \" (\" + m.focus_area + \")\" : \"\")).join(\", \");\n\n    return {\n      json: {\n        company: data.account.name,\n        companySize: null,\n        triggerEvent: {\n          eventType: firstSignal.type || \"Structural Trigger\",\n          description: firstSignal.description || data.posture?.headline || \"\",\n          category: data.account.theme,\n          isActionable: data.posture?.urgency !== \"MONITOR\"\n        },\n        buyingGroup,\n        when_open_with:    data.outreach?.open_with || null,\n        when_action:       data.outreach?.action || null,\n        when_stage:        data.posture?.gate_3 || data.posture?.stage || null,\n        when_urgency:      data.posture?.urgency || null,\n        when_window_close: data.change_triggers?.window_close_date || null,\n        when_whats_at_stake: (data.whats_at_stake || []).map(w => w.role + \": \" + w.statement).join(\" | \") || null,\n        when_the_move:       data.element_4?.the_move || null,\n        when_the_catch:      data.element_4?.the_catch || null,\n        when_your_edge:      data.element_4?.your_edge || null,\n        when_first_step:     data.element_4?.first_step || null,\n        when_campaign_stage: data.outreach?.campaign_stage || null,\n        when_belief_shift:   data.outreach?.belief_shift_objective || null,\n        posture_detail:    data.posture?.detail || null,\n        supporting_signals: data.element_4?.supporting_signals || [],\n        signal_sources:    (data.signals || []).filter(s => s.source_url).map(s => ({ label: s.source_label || s.type || \"source\", url: s.source_url })),\n        industry:          data.account?.industry || null,\n        theme:             data.account?.theme || null,\n        trigger_notes:     data.change_triggers?.notes || null,\n        enrichmentNeeded:  enrichmentNeeded,\n        unenrichedRoles:   unenrichedRoles,\n        _source: \"jocelyn\",\n        _raw: data\n      }\n    };\n  }\n\n  if (data.account_id && data.context_status) {\n    const identity     = data.background?.identity || {};\n    const facts        = data.background?.structural_facts || [];\n    const hypothesis   = data.background?.operational_hypothesis || {};\n    const primaryFact  = facts.find(f => f.type === \"A\") || facts[0] || {};\n    const highTensions = (data.tensions || []).filter(t => t.level === \"HIGH\");\n    const type1Gaps    = data.gaps?.type_1 || [];\n\n    let buyingGroup = (data.stakeholder_map?.buying_committee || []).map(member => ({\n      contactName: member.name || member.contactName,\n      jobTitle:    member.title || member.jobTitle,\n      signals:     [],\n      negativeSignals: highTensions.map(t => ({ type: \"high_tension\", date: new Date().toISOString().split(\"T\")[0], description: t.conflict }))\n    }));\n\n    if (buyingGroup.length === 0) {\n      buyingGroup = [{ contactName: \"Unknown - see Type I gaps\", jobTitle: type1Gaps.map(g => g.gap).join(\" | \") || \"TBD\", signals: [], negativeSignals: highTensions.map(t => ({ type: \"high_tension\", date: new Date().toISOString().split(\"T\")[0], description: t.conflict })) }];\n    }\n\n    return {\n      json: {\n        company:     identity.company || data.account_id,\n        companySize: null,\n        triggerEvent: { eventType: primaryFact.event || \"Structural Event\", description: hypothesis.statement || primaryFact.event || \"\", category: identity.industry || \"Unknown\", isActionable: type1Gaps.length === 0 },\n        buyingGroup,\n        cap_confidence_floor:    data.confidence_floor,\n        cap_primary_archetype:   data.pattern?.primary_archetype || null,\n        cap_secondary_archetype: data.pattern?.secondary_archetype || null,\n        cap_context_status:      data.context_status,\n        cap_type1_gap_count:     type1Gaps.length,\n        cap_high_tension_count:  highTensions.length,\n        _source: \"tabita\",\n        _raw: data\n      }\n    };\n  }\n\n  return { json: { ...data, _source: \"direct\", _raw: data } };\n});"
      },
