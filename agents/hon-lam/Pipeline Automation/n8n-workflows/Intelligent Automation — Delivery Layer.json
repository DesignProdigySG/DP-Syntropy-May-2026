              "id": "a009ef7b-30bf-4522-9503-2bf5a5acbddb",
              "name": "htmlBrief",
              "type": "string",
              "value": "=<html> <body style=\"font-family:Arial;max-width:600px;margin:40px auto;color:#1a1a1a\">\n  <h2 style=\"color:#2563eb\">Sales Brief &#8212; {{ $('Loop Over Items').first().json.company }}</h2>\n  <p style=\"color:#888;font-size:13px\">Generated: {{ $now }}</p>\n  <div style=\"display:flex;gap:16px;margin:12px 0\">\n    <span style=\"background:#2563eb;color:white;padding:4px 12px;border-radius:20px;font-size:13px;font-weight:bold\">Stage {{ $('Loop Over Items').first().json.when_stage }}</span>\n    <span style=\"background:#16a34a;color:white;padding:4px 12px;border-radius:20px;font-size:13px;font-weight:bold\">{{ $('Loop Over Items').first().json.coverageLabel }}</span>\n  </div>\n  {{ $('Loop Over Items').first().json.posture_detail ? '<p style=\"color:#6b7280;font-size:13px;font-style:italic;margin:4px 0 0\">' + $('Loop Over Items').first().json.posture_detail + '</p>' : '' }}\n  <hr style=\"border:1px solid #e5e5e5\">\n  {{ $('Loop Over Items').first().json.enrichmentNeeded ? '<div style=\"background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:10px 12px;margin:0 0 14px;font-size:13px;color:#92400e\"><b>&#9888; Buying group needs enrichment.</b> Unconfirmed: ' + ($('Loop Over Items').first().json.unenrichedRoles || 'contacts') + '. Coverage stays limited until these are confirmed.</div>' : '' }}\n  <p style=\"line-height:1.8;font-size:15px\">{{ $json.output.replace(/[—–]/g, ' - ').replace(/(\\d+\\.)/g, '<br><br>$1') }}</p>\n  {{ $('Loop Over Items').first().json.when_the_catch ? '<div style=\"background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:12px 14px;margin:16px 0\"><div style=\"font-weight:bold;color:#b45309;font-size:13px;margin-bottom:4px\">&#9888; The Catch</div><div style=\"font-size:14px;line-height:1.6\">' + $('Loop Over Items').first().json.when_the_catch + '</div></div>' : '' }}\n  {{ $('Loop Over Items').first().json.when_whats_at_stake ? '<div style=\"margin:16px 0\"><div style=\"font-weight:bold;color:#1f2937;font-size:13px;margin-bottom:6px\">What&#39;s at stake</div><ul style=\"font-size:14px;line-height:1.7;margin:0;padding-left:20px\">' + String($('Loop Over Items').first().json.when_whats_at_stake).split(' | ').map(function(s){ return '<li>' + s + '</li>'; }).join('') + '</ul></div>' : '' }}\n  {{ ($('Loop Over Items').first().json.signal_sources || []).length ? '<div style=\"margin:16px 0 0\"><div style=\"font-weight:bold;color:#1f2937;font-size:13px;margin-bottom:6px\">Sources</div><ul style=\"font-size:13px;line-height:1.6;margin:0;padding-left:20px\">' + ($('Loop Over Items').first().json.signal_sources).map(function(s){ return '<li><a href=\"' + s.url + '\" style=\"color:#2563eb\">' + s.label + '</a></li>'; }).join('') + '</ul></div>' : '' }}\n</body> </html>"
            }
